        {
          "info": {
            "name": "Zitadel List Project Roles",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://{instance}.zitadel.cloud/management/v1/projects/:projectId/roles/_search",
            "params": [
              {
                "name": "projectId",
                "value": "",
                "type": "path",
                "description": "Unique identifier of the project"
              }
            ]
          },
          "docs": "List all roles defined in a project."
