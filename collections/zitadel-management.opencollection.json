          "http": {
            "method": "POST",
            "url": "https://{instance}.zitadel.cloud/management/v1/projects/:projectId/apps/oidc",
            "params": [
              {
                "name": "projectId",
                "value": "",
                "type": "path",
                "description": "Unique identifier of the project"
