{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/HumanProfile",
  "title": "HumanProfile",
  "type": "object",
  "properties": {
    "firstName": {
      "type": "string"
    },
    "lastName": {
      "type": "string"
    },
    "nickName": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "preferredLanguage": {
      "type": "string"
    },
    "gender": {
      "type": "string",
      "enum": [
        "UNSPECIFIED",
        "FEMALE",
        "MALE",
        "DIVERSE"
      ]
    },
    "avatarUrl": {
      "type": "string"
    }
  }
}